# Deployer private key (without 0x prefix)
PRIVATE_KEY=your_private_key_here

# Prediction token address (ERC20 token users will bet with)
# Example: USDC on Base = 0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
PREDICTION_TOKEN=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Admin address (owner who can pause, change settings)
ADMIN_ADDRESS=your_admin_address

# Operator address (runs executeRound, genesisStart, etc.)
OPERATOR_ADDRESS=your_operator_address

# Basescan API key for contract verification
BASESCAN_API_KEY=your_basescan_api_key
